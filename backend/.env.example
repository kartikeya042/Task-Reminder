# Server
PORT=3000
JWT_SECRET=your_super_secret_jwt_key_change_in_production

# MySQL (WSL: use 127.0.0.1 or localhost)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=task_reminder

# SMTP (Gmail example — use an App Password, not your account password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_gmail_app_password

# Email sender display name
EMAIL_FROM=Task Reminder <your_email@gmail.com>

# Frontend URL (used in verification links)
FRONTEND_URL=http://localhost:5173

# WhatsApp (whatsapp-web.js) — optional path to Chrome if auto-detection fails
# CHROME_PATH=C:\Program Files (x86)\Google\Chrome\Application\chrome.exe