# Server (cPanel Phusion Passenger sets PORT automatically)
PORT=5000
JWT_SECRET=your_super_secret_jwt_key_change_in_production

# MySQL
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=task_reminder

# SMTP (Gmail example — use an App Password, not your account password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_gmail_app_password

# Email sender display name
EMAIL_FROM=Task Reminder <your_email@gmail.com>

# Frontend URL (CORS + verification/reset links in emails)
FRONTEND_URL=http://localhost:5173

# WhatsApp microservice URL
WHATSAPP_SERVICE_URL=http://localhost:5001
